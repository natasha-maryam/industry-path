{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlantModel",
  "type": "object",
  "required": ["project_id", "nodes", "edges"],
  "properties": {
    "project_id": {"type": "string"},
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "node_type"],
        "properties": {
          "id": {"type": "string"},
          "node_type": {"type": "string"},
          "process_unit": {"type": ["string", "null"]}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "edge_type"],
        "properties": {
          "source": {"type": "string"},
          "target": {"type": "string"},
          "edge_type": {"type": "string"},
          "confidence": {"type": "number"}
        }
      }
    }
  }
}
